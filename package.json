{
  "name": "claude-code-graph",
  "displayName": "Claude Code Graph",
  "description": "Visualize Claude Code prompts, subagents, and file changes as an interactive graph",
  "version": "0.1.0",
  "publisher": "IdleVillager",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepvairamani/claude-code-graph"
  },
  "keywords": [
    "claude",
    "claude-code",
    "graph",
    "visualization",
    "ai",
    "prompt",
    "agent"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "icon": "media/icons/claude-code-graph.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeIntel.pickSession",
        "title": "Claude Code Graph: Pick Session"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeIntel",
          "title": "Claude Code Graph",
          "icon": "media/icons/claude-intel.svg"
        }
      ]
    },
    "views": {
      "claudeIntel": [
        {
          "type": "webview",
          "id": "claudeIntel.promptGraph",
          "name": "Prompt Graph"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.20.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
